# Crea un nuovo database vuoto e imposta la connection string qui sotto.
# NON puntare mai a un database esistente in produzione.
DATABASE_URL="postgresql://tavolo:tavolo@localhost:5432/tavolo_dev?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"

# Stripe (opzionale per MVP — lasciare vuoto disabilita i pagamenti)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend (opzionale)
RESEND_API_KEY=""
RESEND_FROM="Tavolo <noreply@tavolo.local>"
