generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(cuid())
  email             String            @unique
  name              String?
  passwordHash      String?
  image             String?
  createdAt         DateTime          @default(now())
  totpEnabled       Boolean           @default(false)
  totpSecret        String?
  recoveryCodesHash String[]          @default([])
  sessions          Session[]
  orgMemberships    OrgMembership[]
  venueMemberships  VenueMembership[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  plan         Plan            @default(STARTER)
  createdAt    DateTime        @default(now())
  baseCurrency String          @default("EUR")
  AuditLog     AuditLog[]
  venues       Venue[]
  members      OrgMembership[]
}

model OrgMembership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      OrgRole      @default(OWNER)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_membership")
}

model Venue {
  id                    String               @id @default(cuid())
  orgId                 String
  name                  String
  slug                  String
  kind                  VenueKind            @default(RESTAURANT)
  timezone              String               @default("Europe/Rome")
  currency              String               @default("EUR")
  address               String?
  city                  String?
  country               String?
  phone                 String?
  email                 String?
  coverImage            String?
  active                Boolean              @default(true)
  createdAt             DateTime             @default(now())
  depositPerPersonCents Int                  @default(2000)
  depositThreshold      Int                  @default(8)
  wifiAutoCouponDays    Int                  @default(30)
  wifiAutoCouponEnabled Boolean              @default(false)
  wifiAutoCouponPercent Int                  @default(10)
  wifiPortalAccent      String?              @db.VarChar(9)
  wifiPortalLegal       String?              @db.VarChar(2000)
  wifiPortalLogoUrl     String?
  wifiPortalWelcome     String?              @db.VarChar(500)
  wifiSetupAt           DateTime?
  calendarToken         String?              @unique
  googlePlaceId         String?
  brevoFolderId         Int?
  brandAccent           String?              @db.VarChar(9)
  brandFootnote         String?              @db.VarChar(280)
  brandLogoUrl          String?
  brandSecondaryColor   String?              @db.VarChar(9)
  brandBackgroundColor  String?              @db.VarChar(9)
  brandTypography       BrandTypography?
  websiteUrl            String?
  instagramUrl          String?
  facebookUrl           String?
  googleBusinessUrl     String?
  onboardingStatus      BrandOnboardingStatus @default(NOT_STARTED)
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?
  ApiToken              ApiToken[]
  AutomationWorkflow    AutomationWorkflow[]
  bookings              Booking[]
  CallLog               CallLog[]
  campaigns             Campaign[]
  ChatSession           ChatSession[]
  Connector             Connector[]
  ConsentLog            ConsentLog[]
  CostEntry             CostEntry[]
  Coupon                Coupon[]
  CouponRedemption      CouponRedemption[]
  experiences           Experience[]
  FloorDecor            FloorDecor[]
  GiftCard              GiftCard[]
  guests                Guest[]
  GuestProviderLink     GuestProviderLink[]
  MenuCategory          MenuCategory[]
  MenuItem              MenuItem[]
  MenuItemCost          MenuItemCost[]
  MenuScan              MenuScan[]
  MessageLog            MessageLog[]
  MessageTemplate       MessageTemplate[]
  MissedCall            MissedCall[]
  Notification          Notification[]
  Order                 Order[]
  POSConnector          POSConnector[]
  payments              Payment[]
  QrCode                QrCode[]
  Review                Review[]
  ReviewLink            ReviewLink[]
  ReviewLinkClick       ReviewLinkClick[]
  rooms                 Room[]
  shifts                Shift[]
  StaffShift            StaffShift[]
  Survey                Survey[]
  tables                Table[]
  blocks                TableBlock[]
  org                   Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  WaitlistEntry         WaitlistEntry[]
  WifiLead              WifiLead[]
  WifiSession           WifiSession[]
  members               VenueMembership[]

  @@unique([orgId, slug])
}

model VenueMembership {
  id        String    @id @default(cuid())
  userId    String
  venueId   String
  role      StaffRole @default(RECEPTION)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@map("venue_membership")
}

model Room {
  id         String       @id @default(cuid())
  venueId    String
  name       String
  width      Int          @default(1200)
  height     Int          @default(800)
  ordering   Int          @default(0)
  FloorDecor FloorDecor[]
  venue      Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tables     Table[]
}

model Table {
  id         String       @id @default(cuid())
  venueId    String
  roomId     String?
  label      String
  seats      Int          @default(2)
  shape      TableShape   @default(ROUND)
  posX       Int          @default(0)
  posY       Int          @default(0)
  rotation   Int          @default(0)
  combinable Boolean      @default(true)
  active     Boolean      @default(true)
  height     Int?
  width      Int?
  bookings   Booking[]
  room       Room?        @relation(fields: [roomId], references: [id])
  venue      Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  blocks     TableBlock[]

  @@unique([venueId, label])
}

model TableBlock {
  id       String   @id @default(cuid())
  venueId  String
  tableId  String
  startsAt DateTime
  endsAt   DateTime
  reason   String?
  table    Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  venue    Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model Shift {
  id          String  @id @default(cuid())
  venueId     String
  name        String
  weekday     Int
  startMinute Int
  endMinute   Int
  capacity    Int     @default(80)
  slotMinutes Int     @default(15)
  active      Boolean @default(true)
  venue       Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model Guest {
  id                 String               @id @default(cuid())
  venueId            String
  firstName          String
  lastName           String?
  email              String?
  phone              String?
  birthday           DateTime?
  language           String               @default("it")
  loyaltyTier        LoyaltyTier          @default(NEW)
  totalVisits        Int                  @default(0)
  totalSpend         Decimal              @default(0) @db.Decimal(12, 2)
  noShowCount        Int                  @default(0)
  lastVisitAt        DateTime?
  preferences        Json?
  allergies          String?
  privateNotes       String?
  tags               String[]             @default([])
  marketingOptIn     Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  blocked            Boolean              @default(false)
  blockedAt          DateTime?
  blockedReason      String?              @db.VarChar(400)
  loyaltyPoints      Int                  @default(0)
  anonymizedAt       DateTime?
  anonymizedBy       String?
  bookings           Booking[]
  ConsentLog         ConsentLog[]
  Coupon             Coupon[]
  CouponRedemption   CouponRedemption[]
  venue              Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  GuestProviderLink  GuestProviderLink[]
  LoyaltyTransaction LoyaltyTransaction[]
  MessageLog         MessageLog[]
  Order              Order[]
  payments           Payment[]
  WifiLead           WifiLead[]

  @@index([venueId, email])
  @@index([venueId, phone])
  @@index([venueId, lastName])
}

model Booking {
  id                String             @id @default(cuid())
  reference         String             @unique @default(cuid())
  venueId           String
  guestId           String?
  tableId           String?
  partySize         Int
  startsAt          DateTime
  durationMin       Int                @default(105)
  status            BookingStatus      @default(CONFIRMED)
  source            BookingSource      @default(WIDGET)
  occasion          Occasion?
  notes             String?
  internalNotes     String?
  depositCents      Int                @default(0)
  depositStatus     DepositStatus      @default(NONE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  arrivedAt         DateTime?
  seatedAt          DateTime?
  closedAt          DateTime?
  budgetCents       Int?
  eventType         String?            @db.VarChar(60)
  isGroup           Boolean            @default(false)
  combinedTableIds  String[]           @default([])
  deletedAt         DateTime?
  deletedBy         String?
  guest             Guest?             @relation(fields: [guestId], references: [id])
  table             Table?             @relation(fields: [tableId], references: [id])
  venue             Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  BookingEvent      BookingEvent[]
  BookingPreorder   BookingPreorder?
  payments          Payment[]
  VoiceBookingDraft VoiceBookingDraft?

  @@index([venueId, startsAt])
  @@index([venueId, status])
  @@index([venueId, deletedAt])
}

model Experience {
  id          String   @id @default(cuid())
  venueId     String
  title       String
  slug        String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int      @default(40)
  priceCents  Int      @default(0)
  ticketUrl   String?
  coverImage  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tickets     Ticket[]

  @@unique([venueId, slug])
}

model Ticket {
  id           String       @id @default(cuid())
  experienceId String
  buyerName    String
  buyerEmail   String
  quantity     Int          @default(1)
  totalCents   Int          @default(0)
  status       TicketStatus @default(PAID)
  createdAt    DateTime     @default(now())
  checkedInAt  DateTime?
  checkedInBy  String?
  experience   Experience   @relation(fields: [experienceId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String          @id @default(cuid())
  venueId     String
  name        String
  channel     CampaignChannel @default(EMAIL)
  segment     Json?
  subject     String?
  body        String?
  contentBlocks Json?
  previewText String?
  scheduledAt DateTime?
  status      CampaignStatus  @default(DRAFT)
  // TODO(futuro): estendere con READY/SENDING/FAILED/CANCELLED una volta stabilizzato il wizard
  providerId  String?
  providerListId Int?
  sentCount   Int             @default(0)
  openedCount Int             @default(0)
  bookedCount Int             @default(0)
  createdAt   DateTime        @default(now())
  venue       Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  MessageLog  MessageLog[]
}

enum QrCodeCategory {
  MENU
  BOOKING
  EVENT
  REVIEW
  CAMPAIGN
  SOCIAL
  OTHER
}

model QrCode {
  id             String         @id @default(cuid())
  venueId        String
  name           String
  description    String?
  destinationUrl String
  category       QrCodeCategory @default(OTHER)
  isActive       Boolean        @default(true)
  scansCount     Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  Venue          Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // TODO(futuro): quando esisterà un redirect tracciato (QR -> /r/[id] -> destinationUrl),
  // scansCount si incrementerà lì; oggi resta 0 perché il QR punta direttamente all'URL.
  @@index([venueId, createdAt])
}

model GuestProviderLink {
  id                String   @id @default(cuid())
  venueId           String
  guestId           String
  provider          String
  providerContactId String
  syncedAt          DateTime @default(now())
  Guest             Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  Venue             Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([guestId, provider])
  @@index([venueId, provider])
}

model WebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  payload         Json
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId])
}

model Payment {
  id                String        @id @default(cuid())
  venueId           String
  bookingId         String?
  guestId           String?
  amountCents       Int
  currency          String        @default("EUR")
  kind              PaymentKind   @default(DEPOSIT)
  status            PaymentStatus @default(PENDING)
  stripePaymentId   String?
  createdAt         DateTime      @default(now())
  refundedAt        DateTime?
  deletedAt         DateTime?
  deletedBy         String?
  fxAmountBaseCents Int?
  fxBaseCurrency    String?       @db.VarChar(3)
  fxRateToBase      Decimal?      @db.Decimal(12, 6)
  booking           Booking?      @relation(fields: [bookingId], references: [id])
  guest             Guest?        @relation(fields: [guestId], references: [id])
  venue             Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([venueId, deletedAt])
}

model ApiToken {
  id           String    @id
  venueId      String
  name         String    @db.VarChar(120)
  prefix       String    @unique @db.VarChar(16)
  hashedSecret String
  scopes       String[]  @default([])
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdBy    String?
  createdAt    DateTime  @default(now())
  Venue        Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, revokedAt])
}

model AuditLog {
  id           String       @id
  venueId      String?
  orgId        String
  actorId      String?
  actorEmail   String?
  action       String       @db.VarChar(64)
  entityType   String       @db.VarChar(32)
  entityId     String?
  diff         Json?
  ip           String?      @db.VarChar(64)
  userAgent    String?      @db.VarChar(255)
  createdAt    DateTime     @default(now())
  Organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([orgId, createdAt])
  @@index([venueId, createdAt])
}

model AutomationRun {
  id                 String              @id
  workflowId         String
  venueId            String
  trigger            AutomationTrigger
  status             AutomationRunStatus @default(QUEUED)
  payload            Json?
  result             Json?
  error              String?
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime            @default(now())
  AutomationWorkflow AutomationWorkflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  MessageLog         MessageLog[]

  @@index([venueId, createdAt])
  @@index([workflowId, createdAt])
}

model AutomationWorkflow {
  id            String            @id
  venueId       String
  name          String
  description   String?
  trigger       AutomationTrigger
  active        Boolean           @default(false)
  conditions    Json?
  actions       Json
  delayMinutes  Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime
  createdBy     String?
  AutomationRun AutomationRun[]
  Venue         Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, trigger, active])
}

model BookingEvent {
  id        String           @id
  bookingId String
  kind      BookingEventKind
  message   String?
  meta      Json?
  actorId   String?
  createdAt DateTime         @default(now())
  Booking   Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

model BookingPreorder {
  id                  String                @id
  bookingId           String                @unique
  status              PreorderStatus        @default(DRAFT)
  totalCents          Int                   @default(0)
  notes               String?               @db.VarChar(500)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  Booking             Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  BookingPreorderItem BookingPreorderItem[]
}

model BookingPreorderItem {
  id              String          @id
  preorderId      String
  menuItemId      String?
  name            String
  priceCents      Int
  quantity        Int             @default(1)
  notes           String?         @db.VarChar(200)
  BookingPreorder BookingPreorder @relation(fields: [preorderId], references: [id], onDelete: Cascade)

  @@index([preorderId])
}

model CallLog {
  id                String             @id
  venueId           String
  fromNumber        String
  toNumber          String?
  direction         CallDirection      @default(INBOUND)
  status            CallStatus         @default(QUEUED)
  recordingUrl      String?
  transcript        String?
  durationSec       Int?
  intent            String?
  draftId           String?            @unique
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime           @default(now())
  VoiceBookingDraft VoiceBookingDraft? @relation(fields: [draftId], references: [id])
  Venue             Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

model ChatMessage {
  id          String      @id
  sessionId   String
  role        ChatRole
  text        String
  intent      String?
  payload     Json?
  createdAt   DateTime    @default(now())
  ChatSession ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ChatSession {
  id             String        @id
  venueId        String
  source         ChatSource    @default(WEB)
  guestId        String?
  bookingId      String?
  status         ChatStatus    @default(OPEN)
  draftPartySize Int?
  draftDate      String?
  draftTime      String?
  draftFirstName String?
  draftLastName  String?
  draftEmail     String?
  draftPhone     String?
  draftNotes     String?
  language       String        @default("it")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  ChatMessage    ChatMessage[]
  Venue          Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

model Connector {
  id             String           @id
  venueId        String
  kind           ConnectorKind
  label          String?
  status         ConnectorStatus  @default(DRAFT)
  config         Json?
  webhookSecret  String?
  externalRef    String?
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  Venue          Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  ConnectorEvent ConnectorEvent[]

  @@unique([venueId, kind])
  @@index([venueId, status])
}

model ConnectorEvent {
  id          String               @id
  connectorId String
  venueId     String
  direction   ConnectorDirection
  kind        String
  status      ConnectorEventStatus @default(RECEIVED)
  payload     Json?
  bookingId   String?
  error       String?
  createdAt   DateTime             @default(now())
  Connector   Connector            @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, createdAt])
  @@index([venueId, createdAt])
}

model ConsentLog {
  id        String         @id
  venueId   String
  guestId   String?
  leadId    String?
  channel   ConsentChannel
  granted   Boolean
  source    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime       @default(now())
  Guest     Guest?         @relation(fields: [guestId], references: [id])
  Venue     Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@index([venueId, channel, createdAt])
}

model CostEntry {
  id          String       @id
  venueId     String
  category    CostCategory
  label       String
  amountCents Int
  currency    String       @default("EUR")
  occurredOn  DateTime
  recurring   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  createdBy   String?
  Venue       Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, occurredOn])
}

model Coupon {
  id               String             @id
  venueId          String
  code             String             @unique
  name             String
  description      String?
  kind             CouponKind         @default(PERCENT)
  value            Int                @default(0)
  freeItem         String?
  category         CouponCategory     @default(GENERIC)
  status           CouponStatus       @default(ACTIVE)
  validFrom        DateTime?
  validUntil       DateTime?
  maxRedemptions   Int?
  maxPerGuest      Int                @default(1)
  guestId          String?
  segment          Json?
  redemptionCount  Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Guest            Guest?             @relation(fields: [guestId], references: [id])
  Venue            Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  CouponRedemption CouponRedemption[]

  @@index([venueId, category])
  @@index([venueId, status])
}

model CouponRedemption {
  id          String    @id
  couponId    String
  venueId     String
  guestId     String?
  bookingId   String?
  orderId     String?
  ticketId    String?
  amountCents Int?
  notes       String?
  redeemedAt  DateTime  @default(now())
  redeemedBy  String?
  deletedAt   DateTime?
  deletedBy   String?
  Coupon      Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  Guest       Guest?    @relation(fields: [guestId], references: [id])
  Venue       Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([guestId, redeemedAt])
  @@index([venueId, deletedAt])
  @@index([venueId, redeemedAt])
}

model ExchangeRate {
  id        String   @id
  from      String   @db.VarChar(3)
  to        String   @db.VarChar(3)
  rate      Decimal  @db.Decimal(12, 6)
  fetchedAt DateTime @default(now())

  @@unique([from, to, fetchedAt])
  @@index([from, to])
}

model FloorDecor {
  id        String    @id
  venueId   String
  roomId    String?
  kind      DecorKind
  label     String?
  posX      Int       @default(0)
  posY      Int       @default(0)
  width     Int       @default(80)
  height    Int       @default(80)
  rotation  Int       @default(0)
  color     String?
  createdAt DateTime  @default(now())
  Room      Room?     @relation(fields: [roomId], references: [id])
  Venue     Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

model GiftCard {
  id                 String               @id
  venueId            String
  code               String               @unique
  initialCents       Int
  balanceCents       Int
  currency           String               @default("EUR")
  recipientName      String?
  recipientEmail     String?
  senderName         String?
  message            String?              @db.VarChar(500)
  status             GiftCardStatus       @default(ACTIVE)
  expiresAt          DateTime?
  stripePaymentId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  createdBy          String?
  Venue              Venue                @relation(fields: [venueId], references: [id], onDelete: Cascade)
  GiftCardRedemption GiftCardRedemption[]

  @@index([venueId, status])
}

model GiftCardRedemption {
  id          String   @id
  giftCardId  String
  amountCents Int
  bookingId   String?
  orderId     String?
  reason      String?  @db.VarChar(200)
  createdBy   String?
  createdAt   DateTime @default(now())
  GiftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId, createdAt])
}

model LoyaltyTransaction {
  id        String         @id
  guestId   String
  venueId   String
  kind      LoyaltyTxnKind
  points    Int
  reason    String?        @db.VarChar(200)
  bookingId String?
  orderId   String?
  createdBy String?
  createdAt DateTime       @default(now())
  Guest     Guest          @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId, createdAt])
  @@index([venueId, createdAt])
}

model MenuCategory {
  id        String     @id
  venueId   String
  name      String
  ordering  Int        @default(0)
  menuKey   String     @default("main")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  Venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  MenuItem  MenuItem[]

  @@index([venueId, menuKey, ordering])
}

model MenuItem {
  id           String       @id
  categoryId   String
  venueId      String
  name         String
  description  String?
  priceCents   Int          @default(0)
  currency     String       @default("EUR")
  available    Boolean      @default(true)
  ordering     Int          @default(0)
  allergens    String[]     @default([])
  dietary      String[]     @default([])
  imageUrl     String?
  createdAt    DateTime     @default(now())
  MenuCategory MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  Venue        Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)
  OrderItem    OrderItem[]

  @@index([categoryId, ordering])
}

model MenuItemCost {
  id         String   @id
  venueId    String
  menuItemId String   @unique
  costCents  Int      @default(0)
  updatedAt  DateTime
  Venue      Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
}

model MenuScan {
  id               String         @id
  venueId          String
  menuKey          String         @default("main")
  source           MenuScanSource @default(QR)
  ipHash           String?
  userAgent        String?
  guestId          String?
  email            String?
  phone            String?
  consentMarketing Boolean        @default(false)
  createdAt        DateTime       @default(now())
  Venue            Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

model MessageLog {
  id            String         @id
  venueId       String
  campaignId    String?
  workflowRunId String?
  guestId       String?
  channel       MessageChannel
  toAddress     String
  subject       String?
  bodyPreview   String?
  status        MessageStatus  @default(QUEUED)
  providerId    String?
  error         String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  createdAt     DateTime       @default(now())
  deletedAt     DateTime?
  deletedBy     String?
  Campaign      Campaign?      @relation(fields: [campaignId], references: [id])
  Guest         Guest?         @relation(fields: [guestId], references: [id])
  Venue         Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  AutomationRun AutomationRun? @relation(fields: [workflowRunId], references: [id])

  @@index([campaignId])
  @@index([guestId, channel])
  @@index([venueId, createdAt])
  @@index([venueId, deletedAt])
}

model MessageTemplate {
  id        String           @id
  venueId   String
  name      String
  channel   CampaignChannel  @default(EMAIL)
  subject   String?
  body      String
  category  TemplateCategory @default(GENERIC)
  createdAt DateTime         @default(now())
  updatedAt DateTime
  Venue     Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, name])
  @@index([venueId, category])
}

model MissedCall {
  id             String    @id
  venueId        String
  fromNumber     String
  attempts       Int       @default(1)
  callbackSentAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  Venue          Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
}

model Notification {
  id        String           @id
  venueId   String
  kind      NotificationKind
  title     String           @db.VarChar(160)
  body      String?          @db.VarChar(500)
  link      String?          @db.VarChar(300)
  meta      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  Venue     Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([venueId, readAt])
}

model Order {
  id            String        @id
  reference     String        @unique
  venueId       String
  guestId       String?
  kind          OrderKind     @default(TAKEAWAY)
  status        OrderStatus   @default(RECEIVED)
  paymentStatus PaymentStatus @default(PENDING)
  customerName  String
  phone         String
  email         String?
  address       String?
  scheduledAt   DateTime
  totalCents    Int           @default(0)
  currency      String        @default("EUR")
  notes         String?
  stripeId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  preparedAt    DateTime?
  readyAt       DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  tableLabel    String?       @db.VarChar(40)
  Guest         Guest?        @relation(fields: [guestId], references: [id])
  Venue         Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  OrderItem     OrderItem[]

  @@index([venueId, createdAt])
  @@index([venueId, status, scheduledAt])
}

model OrderItem {
  id         String    @id
  orderId    String
  menuItemId String?
  name       String
  priceCents Int
  quantity   Int       @default(1)
  notes      String?
  MenuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  Order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model POSConnector {
  id            String             @id
  venueId       String
  kind          POSConnectorKind
  label         String?
  status        POSConnectorStatus @default(DRAFT)
  config        Json?
  webhookSecret String?
  externalRef   String?
  lastSyncAt    DateTime?
  lastError     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  Venue         Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  POSEvent      POSEvent[]

  @@unique([venueId, kind])
  @@index([venueId, status])
}

model POSEvent {
  id             String         @id
  posConnectorId String
  venueId        String
  externalRef    String?
  action         String
  amountCents    Int            @default(0)
  currency       String         @default("EUR")
  payload        Json?
  status         POSEventStatus @default(RECEIVED)
  orderId        String?
  error          String?
  createdAt      DateTime       @default(now())
  POSConnector   POSConnector   @relation(fields: [posConnectorId], references: [id], onDelete: Cascade)

  @@index([posConnectorId, createdAt])
  @@index([venueId, createdAt])
}

model Review {
  id           String       @id
  venueId      String
  source       ReviewSource
  externalRef  String?
  externalUrl  String?
  rating       Int
  authorName   String?      @db.VarChar(120)
  authorAvatar String?
  text         String?      @db.VarChar(2000)
  language     String       @default("it")
  publishedAt  DateTime?
  fetchedAt    DateTime     @default(now())
  createdAt    DateTime     @default(now())
  Venue        Venue        @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, source, externalRef])
  @@index([venueId, publishedAt])
}

model ReviewLink {
  id              String            @id
  venueId         String
  platform        ReviewPlatform
  label           String?
  url             String
  ordering        Int               @default(0)
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  Venue           Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  ReviewLinkClick ReviewLinkClick[]

  @@index([venueId, active, ordering])
}

model ReviewLinkClick {
  id         String     @id
  linkId     String
  venueId    String
  surveyId   String?
  npsScore   Int?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime   @default(now())
  ReviewLink ReviewLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  Venue      Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([linkId, createdAt])
  @@index([venueId, createdAt])
}

model StaffShift {
  id          String   @id
  venueId     String
  staffName   String
  role        String?
  date        DateTime
  hours       Float    @default(8)
  hourlyCents Int      @default(1200)
  notes       String?
  createdAt   DateTime @default(now())
  Venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, date])
}

model Survey {
  id             String          @id
  token          String          @unique
  venueId        String
  bookingId      String?         @unique
  guestId        String?
  sentAt         DateTime        @default(now())
  respondedAt    DateTime?
  Venue          Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  SurveyResponse SurveyResponse?

  @@index([venueId, sentAt])
}

model SurveyResponse {
  id        String    @id
  surveyId  String    @unique
  npsScore  Int
  sentiment Sentiment
  comment   String?
  recommend Boolean?
  createdAt DateTime  @default(now())
  Survey    Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model VoiceBookingDraft {
  id            String      @id
  venueId       String
  callerName    String?
  phone         String?
  partySize     Int?
  preferredDate String?
  preferredTime String?
  notes         String?
  status        DraftStatus @default(NEW)
  bookingId     String?     @unique
  reviewedBy    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  CallLog       CallLog?
  Booking       Booking?    @relation(fields: [bookingId], references: [id])

  @@index([venueId, createdAt])
}

model WaitlistEntry {
  id                 String         @id
  venueId            String
  guestId            String?
  guestName          String
  phone              String?
  email              String?
  partySize          Int
  expectedWaitMin    Int            @default(20)
  status             WaitlistStatus @default(WAITING)
  notifiedAt         DateTime?
  seatedAt           DateTime?
  cancelledAt        DateTime?
  position           Int            @default(0)
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  confirmedAt        DateTime?
  convertedBookingId String?
  declinedAt         DateTime?
  offerExpiresAt     DateTime?
  offerSentVia       String?        @db.VarChar(20)
  offerToken         String?        @unique
  Venue              Venue          @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, status, createdAt])
}

model WifiLead {
  id               String        @id
  venueId          String
  guestId          String?
  name             String
  email            String?
  phone            String?
  source           String?
  ipAddress        String?
  userAgent        String?
  consentMarketing Boolean       @default(false)
  consentPrivacy   Boolean       @default(true)
  createdAt        DateTime      @default(now())
  Guest            Guest?        @relation(fields: [guestId], references: [id])
  Venue            Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  WifiSession      WifiSession[]

  @@index([venueId, createdAt])
  @@index([venueId, email])
  @@index([venueId, phone])
}

model WifiSession {
  id          String    @id
  leadId      String
  venueId     String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int?
  ipAddress   String?
  userAgent   String?
  deviceType  String?
  WifiLead    WifiLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  Venue       Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, startedAt])
}

